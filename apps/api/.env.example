# dev | prod — selects DATABASE_URL_DEV vs DATABASE_URL_PROD when DATABASE_URL is unset
APP_ENV=dev

# Exact browser origin for CORS (no trailing slash). Local: http://localhost:3000
# Production: https://<your-vercel-app>.vercel.app
WEB_URL=http://localhost:3000

# Single URL for Prisma (recommended for production on Render: set APP_ENV=prod and use DATABASE_URL only)
# Supabase: use the connection string with SSL (often includes sslmode=require)
DATABASE_URL=

# Optional split URLs when DATABASE_URL is not set (see prisma.config.ts)
DATABASE_URL_DEV=postgresql://user:password@host:5432/dev_dbname
DATABASE_URL_PROD=postgresql://user:password@host:5432/prod_dbname

JWT_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret

# Set by Render in production; optional locally
PORT=3001

# production enables Secure cookies for auth
NODE_ENV=development
