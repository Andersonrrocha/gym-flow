generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String               @id @default(uuid())
  email            String               @unique
  password         String
  refreshToken     String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  createdExercises Exercise[]           @relation("UserCreatedExercises")
  workouts         Workout[]
  workoutSchedules WorkoutSchedule[]
  workoutSessions  WorkoutSession[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Exercise {
  id                String            @id @default(uuid())
  name              String
  /** Chave estável para i18n (ex.: bench_press). Só exercícios de sistema; utilizadores usam só `name`. */
  catalogKey        String?           @unique
  muscleGroup       String?
  equipment         String?
  isSystem          Boolean           @default(true)
  createdByUserId   String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  createdByUser     User?             @relation("UserCreatedExercises", fields: [createdByUserId], references: [id], onDelete: SetNull)
  workoutExercises  WorkoutExercise[]
  sessionExercises  SessionExercise[]

  @@index([createdByUserId])
  @@index([muscleGroup])
  @@index([equipment])
}

model Workout {
  id            String            @id @default(uuid())
  userId        String
  name          String
  description   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises     WorkoutExercise[]
  schedules     WorkoutSchedule[]
  sessions      WorkoutSession[]

  @@index([userId])
}

model WorkoutExercise {
  id           String             @id @default(uuid())
  workoutId    String
  exerciseId   String
  order        Int
  plannedSets  Int?
  plannedReps  String?
  restSeconds  Int?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  workout      Workout            @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise     Exercise           @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  sessionItems SessionExercise[]

  @@index([workoutId])
  @@index([exerciseId])
  @@unique([workoutId, order])
}

model WorkoutSchedule {
  id        String   @id @default(uuid())
  userId    String
  workoutId String
  weekday   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout   Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workoutId])
  @@index([weekday])
  @@unique([userId, weekday])
}

model WorkoutSession {
  id             String               @id @default(uuid())
  userId         String
  workoutId      String?
  status         WorkoutSessionStatus @default(IN_PROGRESS)
  startedAt      DateTime             @default(now())
  finishedAt     DateTime?
  performedAt    DateTime             @default(now())
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout        Workout?             @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  sessionItems   SessionExercise[]

  @@index([userId])
  @@index([workoutId])
  @@index([performedAt])
}

model SessionExercise {
  id                String          @id @default(uuid())
  sessionId         String
  exerciseId        String
  workoutExerciseId String?
  nameSnapshot      String
  plannedSets       Int?
  plannedReps       String?
  order             Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  session           WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise          Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  workoutExercise   WorkoutExercise? @relation(fields: [workoutExerciseId], references: [id], onDelete: SetNull)
  sets              SessionSet[]

  @@index([sessionId])
  @@index([exerciseId])
  @@index([workoutExerciseId])
  @@unique([sessionId, order])
}

model SessionSet {
  id                String          @id @default(uuid())
  sessionExerciseId String
  reps              Int
  weight            Float
  setNumber         Int
  createdAt         DateTime        @default(now())
  sessionExercise   SessionExercise @relation(fields: [sessionExerciseId], references: [id], onDelete: Cascade)

  @@index([sessionExerciseId])
  @@unique([sessionExerciseId, setNumber])
}

enum WorkoutSessionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
